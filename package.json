{
  "name": "stealth-ai-solver",
  "version": "2.0.0",
  "description": "Invisible AI assistant powered by local Ollama — no API keys needed",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "tesseract.js": "^5.0.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.stealth.solver",
    "productName": "Stealth AI Solver",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
